{
  // テスト専用 tsconfig。cloudflare:test モジュール (SELF, env 等) の型を解決するために必要。
  // 本体の workers/collab/tsconfig.json とは分離して管理する。
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "types": ["@cloudflare/vitest-pool-workers"]
  },
  "include": ["../src/**/*.test.ts", "../src/**/*.spec.ts"],
  // 親 tsconfig はテストファイルを exclude するが、本ファイルは逆にテストを
  // include して型解決する目的なので、継承された exclude を空で打ち消す。
  "exclude": []
}
