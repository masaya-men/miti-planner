rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ========================================
    // ヘルパー関数
    // ========================================

    // 認証済みかどうか
    function isAuthenticated() {
      return request.auth != null;
    }

    // 自分自身のドキュメントか
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // 文字列の長さ制限チェック
    function isValidString(s, maxLen) {
      return s is string && s.size() > 0 && s.size() <= maxLen;
    }

    // ========================================
    // users コレクション
    // 自分のプロファイルのみ読み書き可能
    // メールアドレスの保存を明示的に禁止
    // ========================================
    match /users/{uid} {
      allow read: if isOwner(uid);

      allow create: if isOwner(uid)
                    && isValidString(request.resource.data.displayName, 30)
                    && request.resource.data.keys().hasAll(['displayName', 'provider', 'createdAt', 'updatedAt', 'settings'])
                    && !('email' in request.resource.data)
                    && request.resource.data.provider in ['discord'];

      allow update: if isOwner(uid)
                    && isValidString(request.resource.data.displayName, 30)
                    && !('email' in request.resource.data)
                    && request.resource.data.provider == resource.data.provider  // プロバイダ変更禁止
                    && request.resource.data.keys().hasAll(['displayName', 'provider', 'createdAt', 'updatedAt', 'settings']);  // 必須フィールドの存在を強制

      allow delete: if isOwner(uid);
    }

    // ========================================
    // plans コレクション
    // 読み取り: 自分のプラン OR 公開プラン
    // 書き込み: 自分のプランのみ
    // ========================================
    match /plans/{planId} {
      // 読み取り: 自分のプランのみ (公開プランの client 直読みは撤去)。
      // 共有は /api/share (shared_plans・Admin SDK)、collab は /api/collab/load (Admin SDK) 経由で
      // plans を読むため client の公開読みは不要。攻撃者の直 list を permission-denied にする。
      allow read: if isOwner(resource.data.ownerId);

      allow create: if isAuthenticated()
                    && request.resource.data.ownerId == request.auth.uid
                    && isValidString(request.resource.data.title, 100)
                    && request.resource.data.contentId is string
                    && request.resource.data.isPublic is bool
                    && request.resource.data.data is map
                    && request.resource.data.version == 1
                    && request.resource.data.copyCount == 0
                    && request.resource.data.useCount == 0;

      allow update: if isOwner(resource.data.ownerId)
                    // オーナーIDの変更禁止
                    && request.resource.data.ownerId == resource.data.ownerId
                    // copyCount/useCountの改ざん防止（クライアントからは変更不可・両分岐共通）
                    && request.resource.data.copyCount == resource.data.copyCount
                    && request.resource.data.useCount == resource.data.useCount
                    && (
                      // (A) ソフトデリート (墓標化): deleted=true をセットする更新。
                      //     内容フィールドの妥当性は不問 (削除済み doc は表示・カウント対象外)。
                      request.resource.data.deleted == true
                      ||
                      // (B) 通常更新: 内容フィールドの型検証 + 楽観的ロック
                      (
                        isValidString(request.resource.data.title, 100)
                        && request.resource.data.data is map
                        && request.resource.data.isPublic is bool
                        && request.resource.data.contentId is string
                        && request.resource.data.version > resource.data.version
                      )
                    );

      // 物理削除: 通常のプラン削除はソフトデリート (update で deleted=true) を使うが、
      // アカウント全削除 (useAuthStore) は本人のプランをまとめて物理削除するため許可を維持。
      // 古い墓標の定期物理削除は GC cron が Admin SDK で実施 (rules バイパス)。
      allow delete: if isOwner(resource.data.ownerId);
    }

    // 共同編集⑤: roomToken → plan 対応表。発行・取得・失効はすべて
    // /api/collab/room と /api/collab/{load,save}(admin SDK・rules バイパス)経由。
    // クライアントからの直接アクセスは一切許可しない(public repo の明示防御)。
    match /collabRooms/{roomToken} {
      allow read, write: if false;
    }

    // ========================================
    // sharedPlanMeta コレクション
    // 読み取り: 誰でも（共有URLの解決に必要）
    // 書き込み: プラン所有者のみ
    // ========================================
    match /sharedPlanMeta/{shareId} {
      // read はアカウント削除の where('ownerId','==',uid) のみが使う (共有解決は shared_plans/Admin SDK 経由)。
      allow read: if isOwner(resource.data.ownerId);

      allow create: if isAuthenticated()
                    && request.resource.data.ownerId == request.auth.uid
                    && isValidString(request.resource.data.title, 100)
                    && request.resource.data.planId is string
                    && request.resource.data.isActive == true;

      allow update: if isOwner(resource.data.ownerId)
                    // ownerIdの変更禁止
                    && request.resource.data.ownerId == resource.data.ownerId
                    && isValidString(request.resource.data.title, 100)
                    && request.resource.data.planId is string;

      allow delete: if isOwner(resource.data.ownerId);
    }

    // ========================================
    // userPlanCounts コレクション
    // プラン数上限を強制するためのカウンター
    // ========================================
    match /userPlanCounts/{uid} {
      allow read: if isOwner(uid);

      // 初回作成: total=0, byContent=空マップ
      allow create: if isOwner(uid)
                    && request.resource.data.total == 0
                    && request.resource.data.byContent is map
                    && request.resource.data.byContent.keys().size() == 0;

      // 更新: 上限チェック（全体50件、コンテンツ別5件）
      allow update: if isOwner(uid)
                    && request.resource.data.total >= 0
                    && request.resource.data.total <= 50;
                    // byContent内の各値のチェックはCloud Functionsで補完

      // カウンターの直接削除は禁止（アカウント削除時はCloud Functionsで処理）
      allow delete: if false;
    }

    // ========================================
    // admin_logs コレクション
    // 監査ログ: 管理者のみ読める・直接書き込み不可（API経由のみ）
    // ========================================
    match /admin_logs/{logId} {
      allow read: if request.auth != null && request.auth.token.role == 'admin';
      allow write: if false;
    }

    // ========================================
    // master コレクション
    // マスターデータ: 誰でも読める・直接書き込み不可（API経由のみ）
    // ========================================
    match /master/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // ========================================
    // shared_plans サブコレクション copiedBy
    // コピー追跡: サーバーサイドのみ（クライアント直接アクセス不可）
    // ========================================
    match /shared_plans/{shareId}/copiedBy/{uid} {
      allow read: if false;
      allow write: if false;
    }

    // ========================================
    // shared_plans サブコレクション anonCopiedBy
    // 匿名コピー追跡: サーバーサイドのみ（クライアント直接アクセス不可）
    // ========================================
    match /shared_plans/{shareId}/anonCopiedBy/{anonId} {
      allow read: if false;
      allow write: if false;
    }

    // ========================================
    // templates コレクション
    // テンプレート: 誰でも読める・直接書き込み不可
    // ========================================
    match /templates/{contentId} {
      // 単一 get: 公開読み窓口 (/api/template?action=public-template) の miss フォールバックとして残す。
      // list (バルク列挙): 撤去 (大量列挙ベクタ)。テンプレは窓口経由で配る。
      allow get: if true;
      allow list: if false;
      allow write: if false;
    }

    // ========================================
    // template_backups コレクション
    // テンプレートバックアップ: 管理者のみ読める・直接書き込み不可
    // ========================================
    match /template_backups/{docId} {
      allow read: if request.auth != null && request.auth.token.role == 'admin';
      allow write: if false;
    }

    // ========================================
    // master_backups コレクション
    // マスターバックアップ: 管理者のみ読める・直接書き込み不可
    // ========================================
    match /master_backups/{docId} {
      allow read: if request.auth != null && request.auth.token.role == 'admin';
      allow write: if false;
    }

    // ========================================
    // ハウジング: helper 関数
    // ========================================

    function isValidHousingArea(area) {
      return area in ['Mist', 'LavenderBeds', 'Goblet', 'Shirogane', 'Empyreum'];
    }

    function isValidHousingSize(size) {
      return size in ['S', 'M', 'L'];
    }

    function isValidImageMode(mode) {
      return mode in ['sns', 'thumbnail', 'none'];
    }

    function isValidWard(ward) {
      return ward is int && ward >= 1 && ward <= 30;
    }

    function isValidPlot(plot) {
      return plot is int && plot >= 1 && plot <= 60;     // 通し番号: 本街 1-30、 拡張街 31-60
    }

    function isValidTags(tags) {
      return tags is list && tags.size() <= 5;
    }

    function isValidDescription(desc) {
      return desc is string && desc.size() <= 200;
    }

    function isValidApartmentRoom(room) {
      return room is int && room >= 1 && room <= 90;
    }

    function isValidBuildingType(t) {
      return t in ['house', 'apartment'];
    }

    function isValidPrivateChamberNumber(n) {
      return n is int && n >= 1 && n <= 512;
    }

    function isValidTourListings(listings) {
      return listings is list && listings.size() <= 100;
    }

    // ========================================
    // housing_listings コレクション
    // get (1件直接取得): canViewListing (src/lib/housing/listingVisibility.ts) と等価にサーバー強制。
    //   削除済み(deletedAt)は誰も不可、通報非表示(isHidden)/非公開(private)/公開期限切れ(publishUntil)は
    //   他人不可・本人のみ可。getListingById の直接 getDoc がルールをすり抜けて漏らすのを防ぐ。
    // list (一覧クエリ): 公開かつ非表示でない、または本人。deletedAt/publishUntil は query の where +
    //   client filter で除外する (これらを list ルールに入れると、同条件で絞らないクエリが
    //   permission-denied で壊れるため、状態ガードは get のみに課す)。
    // 書き込み: 認証済み + 所有者のみ
    // ========================================
    match /housing_listings/{listingId} {
      allow get: if (!('deletedAt' in resource.data) || resource.data.deletedAt == null)
                 && (
                   (isAuthenticated() && resource.data.ownerUid == request.auth.uid)
                   || (
                     resource.data.isHidden == false
                     && resource.data.visibility == 'public'
                     && (!('publishUntil' in resource.data)
                         || resource.data.publishUntil == null
                         || request.time.toMillis() < resource.data.publishUntil)
                   )
                 );

      // 2026-07-14 (P1): 公開一覧の直バルク list はキャッシュ窓口 (api/housing/public) に一本化した。
      // クライアント直 list はオーナー本人の自分読み (getMyListings) のみ許可し、
      // 公開キーでの where(...).limit(N) 全件ループを permission-denied で止める。
      // 単体 get (allow get) は §13 に従い今回は据え置き (公開詳細も get 可のまま)。
      allow list: if isAuthenticated() && resource.data.ownerUid == request.auth.uid;

      allow create: if isAuthenticated()
                    && request.auth.uid == request.resource.data.ownerUid
                    && request.resource.data.dc is string
                    && request.resource.data.server is string
                    && isValidHousingArea(request.resource.data.area)
                    && isValidWard(request.resource.data.ward)
                    && isValidBuildingType(request.resource.data.buildingType)
                    && isValidImageMode(request.resource.data.imageMode)
                    && isValidTags(request.resource.data.tags)
                    && (!('description' in request.resource.data) || isValidDescription(request.resource.data.description))
                    && request.resource.data.addressKey is string
                    && request.resource.data.addressKey.size() <= 200
                    && request.resource.data.reportCount == 0
                    && request.resource.data.isHidden == false
                    && (!('visibility' in request.resource.data)
                        || request.resource.data.visibility in ['public', 'private'])
                    // === buildingType 別の制約 (3 パターン) ===
                    && (
                      // house パターン (家全体 or FC 個室)
                      (
                        request.resource.data.buildingType == 'house'
                        && isValidPlot(request.resource.data.plot)
                        && isValidHousingSize(request.resource.data.size)
                        && (
                          // 家全体: roomKind / roomNumber なし
                          !('roomKind' in request.resource.data)
                          || (
                            // FC 個室: roomNumber 1-512
                            request.resource.data.roomKind == 'private_chamber'
                            && isValidPrivateChamberNumber(request.resource.data.roomNumber)
                          )
                        )
                      )
                      ||
                      // apartment パターン: plot/size なし、 roomKind='apartment_room' 必須、 roomNumber 1-90
                      (
                        request.resource.data.buildingType == 'apartment'
                        && !('plot' in request.resource.data)
                        && !('size' in request.resource.data)
                        && request.resource.data.roomKind == 'apartment_room'
                        && isValidApartmentRoom(request.resource.data.roomNumber)
                      )
                    );

      allow update: if isOwner(resource.data.ownerUid)
                    && request.resource.data.ownerUid == resource.data.ownerUid
                    && request.resource.data.addressKey == resource.data.addressKey
                    // reportCount / isHidden / deletedAt はクライアントから直接変更不可（API ハンドラ経由のみ）
                    && request.resource.data.reportCount == resource.data.reportCount
                    && request.resource.data.isHidden == resource.data.isHidden
                    && (
                      // deletedAt: 既存 doc が field を持たない場合は新規追加禁止、 持つ場合は同一値のみ
                      (!('deletedAt' in resource.data) && !('deletedAt' in request.resource.data))
                      || (('deletedAt' in resource.data) && request.resource.data.deletedAt == resource.data.deletedAt)
                    )
                    && (!('visibility' in request.resource.data)
                        || request.resource.data.visibility in ['public', 'private'])
                    && isValidHousingArea(request.resource.data.area)
                    && isValidWard(request.resource.data.ward)
                    && isValidBuildingType(request.resource.data.buildingType)
                    && isValidImageMode(request.resource.data.imageMode)
                    && isValidTags(request.resource.data.tags)
                    && (!('description' in request.resource.data) || isValidDescription(request.resource.data.description))
                    && (
                      (
                        request.resource.data.buildingType == 'house'
                        && isValidPlot(request.resource.data.plot)
                        && isValidHousingSize(request.resource.data.size)
                        && (
                          !('roomKind' in request.resource.data)
                          || (
                            request.resource.data.roomKind == 'private_chamber'
                            && isValidPrivateChamberNumber(request.resource.data.roomNumber)
                          )
                        )
                      )
                      ||
                      (
                        request.resource.data.buildingType == 'apartment'
                        && !('plot' in request.resource.data)
                        && !('size' in request.resource.data)
                        && request.resource.data.roomKind == 'apartment_room'
                        && isValidApartmentRoom(request.resource.data.roomNumber)
                      )
                    );

      // 物理削除はクライアントから禁止 (Admin SDK のみ、 soft delete は API 経由で deletedAt をセット、 30 日後 cron で物理削除)
      allow delete: if false;

      // 通報サブコレクション
      match /reports/{reportId} {
        // 読み: 管理者のみ
        allow read: if request.auth != null && request.auth.token.admin == true;
        // 作成: 認証ユーザー、 reporterUid は自分自身、 reason は有効値のみ
        allow create: if isAuthenticated()
                      && request.auth.uid == request.resource.data.reporterUid
                      && request.resource.data.reason in ['wrong_info', 'griefing', 'nsfw', 'sold', 'other'];
        allow update, delete: if false;
      }
    }

    // ========================================
    // housing_meta コレクション (2026-07-14 P1)
    // 公開データの版番号 (public.version)。窓口/クライアントが read するので公開、
    // 書き込みは Admin SDK (全書き込みハンドラの increment) のみ。
    // ========================================
    match /housing_meta/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // ========================================
    // users/{uid}/notifications コレクション
    // アプリ内通知 (家主への通報通知等)
    // 作成・削除: Admin SDK 経由のみ
    // ========================================
    match /users/{uid}/notifications/{notificationId} {
      // 読: 本人のみ
      allow read: if request.auth != null && request.auth.uid == uid;
      // 更新: 本人のみ、 既読フラグの更新だけ許可
      allow update: if request.auth != null
                    && request.auth.uid == uid
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['read', 'readAt']);
      // 作成・削除: Admin SDK 経由のみ
      allow create, delete: if false;
    }

    // ========================================
    // housing_tours コレクション
    // 読み取り: 公開ツアー OR 所有者
    // 書き込み: 所有者のみ
    // ========================================
    match /housing_tours/{tourId} {
      allow read: if (resource != null && resource.data.isPublic == true)
                  || isOwner(resource.data.ownerUid);

      allow create: if isAuthenticated()
                    && request.auth.uid == request.resource.data.ownerUid
                    && isValidString(request.resource.data.title, 50)
                    && isValidTourListings(request.resource.data.listingIds)
                    && request.resource.data.isPublic is bool;

      allow update: if isOwner(resource.data.ownerUid)
                    && request.resource.data.ownerUid == resource.data.ownerUid
                    && isValidString(request.resource.data.title, 50)
                    && isValidTourListings(request.resource.data.listingIds);

      allow delete: if isOwner(resource.data.ownerUid);
    }

    // ========================================
    // housing_favorites コレクション
    // /housing_favorites/{uid}/items/{listingId}
    // 100 件上限は Cloud Function で集計（rules では direct 検証不可）
    // ========================================
    match /housing_favorites/{uid}/items/{listingId} {
      allow read: if isOwner(uid);
      allow write: if isOwner(uid);
    }

    // ========================================
    // housing_user_meta コレクション
    // 書き込みは Cloud Function 経由のみ（クライアントは登録枠改ざん不可）
    // ========================================
    match /housing_user_meta/{uid} {
      allow read: if isOwner(uid);
      allow write: if false;
    }

    // ========================================
    // housing_profiles コレクション
    // ハウジンガー公開プロフィール (spec 2026-07-10-housinger-profile-design.md)
    // 書き込みは API (Admin SDK) のみ。公開条件を満たすか本人のみ読める。
    // ========================================
    match /housing_profiles/{uid} {
      allow get, list: if (resource.data.isPublished == true
                           && resource.data.isModerationHidden == false)
                       || isOwner(uid);
      allow write: if false;

      // プロフィール通報 (API 経由のみ。読みは管理者)
      match /reports/{reportId} {
        allow read: if request.auth != null && request.auth.token.admin == true;
        allow write: if false;
      }
    }

    // ========================================
    // users/{uid}/featureSessions/{tool}
    // ツール毎 opt-in フラグ
    // ========================================
    match /users/{uid}/featureSessions/{tool} {
      allow read: if isOwner(uid);
      allow create, update: if isOwner(uid)
                            && tool in ['miti', 'housing']
                            && request.resource.data.activated is bool;
      allow delete: if isOwner(uid);
    }

    // ========================================
    // system_notifications コレクション
    // read: public (全ユーザー閲覧可、 認証不要)
    // write: client から不可 (admin API + Firebase Admin SDK 経由のみ)
    // ========================================
    match /system_notifications/{id} {
      // 公開読みは /api/template?action=public-notifications (Admin SDK・キャッシュ) 経由に一本化。
      // client 直読みは管理画面 (AdminSystemNotifications) の admin のみ残す。admin claim = role:'admin'。
      allow read: if request.auth != null && request.auth.token.role == 'admin';
      allow write: if false;
    }

    // ========================================
    // personal_tags コレクション (2026-07-10 タグ体系刷新 Phase B)
    // 1 ユーザー 1 個の強制・作成・通報カウント更新は全て /api/housing 経由 (Admin SDK) で行うため、
    // 書き込みは client から一切不可 (housing_user_meta と同じ「サーバー権威データ」パターン)。
    // 読み取りは公開タグの解決・検索用に isHidden=false を誰でも許可、 本人は非表示でも自分の分だけ見える。
    // ========================================
    match /personal_tags/{tagId} {
      allow get: if resource.data.isHidden == false
                 || (isAuthenticated() && resource.data.ownerUid == request.auth.uid);
      allow list: if resource.data.isHidden == false;
      allow write: if false;

      // 通報 (doc ID = reporterUid で 1 ユーザー 1 通報を dedup)。 作成・カウント更新は API 経由のみ。
      match /reports/{reporterUid} {
        allow read: if request.auth != null && request.auth.token.admin == true;
        allow write: if false;
      }
    }

    // ========================================
    // その他すべてのパスへのアクセスを拒否
    // ========================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
