# FFLogs API credentials for local development
# 
# How to get these:
#   1. Go to https://www.fflogs.com/api/clients/
#   2. Click "Create Client"
#   3. Name: e.g. "Miti Planner Dev"
#   4. Redirect URL: http://localhost (required but not used)
#   5. Copy the generated Client ID and Client Secret below
#
# IMPORTANT: This file (.env.local) is already listed in .gitignore (via *.local)
# and will NEVER be committed to GitHub. Keep your secret safe.

VITE_FFLOGS_CLIENT_ID=your_client_id_here
VITE_FFLOGS_CLIENT_SECRET=your_client_secret_here
