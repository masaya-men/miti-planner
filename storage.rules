rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /icons/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.role == 'admin';
    }

    // OGP画像キャッシュ: 誰でも読み取り可能、書き込みはサーバー(admin SDK)のみ
    // admin SDK は rule をバイパスするため、クライアントからの直接書き込みは全て拒否する
    match /og-images/{hash} {
      allow read: if true;
      allow write: if false;
    }

    // ユーザーのチームロゴ・アバター: 誰でも読み取り可能、本人のみ書き込み・削除可能
    match /users/{userId}/{file} {
      allow read: if true;
      allow delete: if request.auth != null && request.auth.uid == userId;
      allow create, update: if request.auth != null
                      && request.auth.uid == userId
                      && file.matches('(team-logo\\.(jpg|webp)|avatar\\.webp)')
                      && request.resource.size < 2 * 1024 * 1024
                      && request.resource.contentType.matches('image/.*');
    }

    // ハウジング物件の画像 (2026-05-26 追加): 誰でも読み取り可能、
    // 書き込みは backend (admin SDK) 経由のみ。 admin SDK は rule をバイパスするため、
    // クライアントからの直接書き込みは全て拒否する。
    // backend 側で listing.ownerUid とリクエスト UID の一致を検証する。
    match /housing/listings/{listingId}/{file} {
      allow read: if true;
      allow write: if false;
    }
  }
}
